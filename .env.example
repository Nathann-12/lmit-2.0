# Copy to .env and change secrets before deploy:
#   copy .env.example .env

DB_NAME=lmit
JWT_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-deploy
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost,http://127.0.0.1

# Leave empty when using Docker (nginx proxies /api to backend)
REACT_APP_BACKEND_URL=

# Host port: 8080 for local dev, 80 for production VPS
HTTP_PORT=8080
